shift + cmd - h : yabai -m window --focus west || yabai -m space --focus prev
shift + cmd - j : yabai -m window --focus stack.prev || yabai -m window --focus south
shift + cmd - k : yabai -m window --focus stack.next || yabai -m window --focus north
shift + cmd - l : yabai -m window --focus east || yabai -m space --focus next

shift + cmd - y : yabai -m window --resize left:-15:0 || yabai -m window --resize right:-15:0
shift + cmd - u : yabai -m window --resize bottom:0:15 || yabai -m window --resize top:0:15
shift + cmd - i : yabai -m window --resize top:0:-15 || yabai -m window --resize bottom:0:-15
shift + cmd - o : yabai -m window --resize right:15:0 || yabai -m window --resize left:15:0

ctrl + cmd - h : yabai -m window --space prev --focus
ctrl + cmd - l : yabai -m window --space next --focus

shift + cmd - f : yabai -m window --toggle zoom-fullscreen
